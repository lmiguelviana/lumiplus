# Configuração Lumi Plus

# DATABASE_URL:
# 1. Supabase/Postgres: "postgresql://USER:PASSWORD@HOST:5432/DATABASE"
# 2. SQLite Local: "file:./dev.db" (Nota: Mudar provider no schema.prisma para "sqlite")
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lumiplus_db?schema=public"

JWT_SECRET="sua_chave_secreta_de_pelo_menos_32_chars"
OPENROUTER_API_KEY="sk-or-your-key-here"
VAULT_MASTER_KEY="000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f"
EMBEDDING_MODEL="openai/text-embedding-3-small"
