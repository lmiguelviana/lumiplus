# ─────────────────────────────────────────────
#  LumiPlus — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────

# ── Banco de Dados (obrigatório) ──
# PostgreSQL (recomendado para produção):
DATABASE_URL="postgresql://lumiplus:lumiplus@postgres:5432/lumiplus_db?schema=public"
# SQLite (instalação local sem banco externo):
# DATABASE_URL="file:./dev.db"

# ── Segurança (obrigatório) ──
# Mínimo 32 caracteres aleatórios
JWT_SECRET="troque_por_string_aleatoria_de_pelo_menos_32_chars_aqui"
# Exatamente 64 chars hex (32 bytes) — gere com: openssl rand -hex 32
VAULT_MASTER_KEY="000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f"

# ── IA / OpenRouter (obrigatório para IA funcionar) ──
OPENROUTER_API_KEY="sk-or-v1-xxxx"

# ── Redis (opcional — fila BullMQ para workflows) ──
# Se não definido, workflows rodam em memória
REDIS_URL="redis://redis:6379"

# ── Dashboard (URL pública para CORS) ──
DASHBOARD_URL="http://localhost:3000"

# ── Porta do backend ──
PORT=3001
NODE_ENV="production"

# ─────────────────────────────────────────────
# OPCIONAIS — configure conforme necessidade
# ─────────────────────────────────────────────

# ── RAG / Embeddings ──
EMBEDDING_MODEL="openai/text-embedding-3-small"

# ── Canais externos ──
# TELEGRAM_BOT_TOKEN=""
# DISCORD_BOT_TOKEN=""
# BRAVE_SEARCH_API_KEY=""

# ── Supabase (se usar Supabase como banco) ──
# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""
